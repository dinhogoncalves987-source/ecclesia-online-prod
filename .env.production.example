# ══════════════════════════════════════════════════════════════════════════
# Ecclesia Online — variáveis do ambiente de PRODUÇÃO (Vercel Project: prod)
# ══════════════════════════════════════════════════════════════════════════
#
# Modelo sem valores reais. Configure estes nomes em:
#   Vercel → Projeto de Produção → Settings → Environment Variables
#     (Environment: Production, branch "main")
#
# scripts/check-environment.mjs recusa o build de produção se:
#   - VITE_APP_ENV != "production";
#   - a branch não for "main" (quando detectável);
#   - o domínio não for o domínio oficial;
#   - o project ref não corresponder ao ref de produção configurado.

VITE_APP_ENV=production

# Projeto Supabase de PRODUÇÃO (Ecclesia-Admin). O project ref é um
# identificador PÚBLICO (não é segredo) e é FIXO/CANÔNICO — produção só
# pode usar zsonukpxahaxffugavfu (ver CANONICAL_PROJECT_REF em
# src/config/environment.ts e scripts/check-environment.mjs).
VITE_SUPABASE_URL=https://zsonukpxahaxffugavfu.supabase.co
VITE_SUPABASE_PUBLISHABLE_KEY=sb_publishable_SUBSTITUA_AQUI
VITE_EXPECTED_SUPABASE_PROJECT_REF=zsonukpxahaxffugavfu

# Domínio oficial de produção (fixo/canônico).
VITE_PUBLIC_APP_URL=https://ecclesiabr.online

# fail-closed: produção declara explicitamente "false". Qualquer outro
# valor além de exatamente "true" já é tratado como false pelo app.
VITE_ENABLE_LEGACY_CHURCH_SCOPE_FALLBACK=false

# Allowlist urgente de gestão (ver src/config/modules.ts). Deixe vazio para
# usar somente a allowlist central — não adicione módulos de staging aqui.
VITE_ENABLED_MODULES=

# ── Somente para scripts/check-environment.mjs (build-time, Node) ─────────
# Refs canônicos e imutáveis — devem ser exatamente estes valores; o script
# recusa o build se forem omitidos, iguais entre si, ou diferentes destes.
SUPABASE_PRODUCTION_REF=zsonukpxahaxffugavfu
SUPABASE_STAGING_REF=qkiiwopkbcslquyfhdec
OFFICIAL_PRODUCTION_DOMAIN=ecclesiabr.online
