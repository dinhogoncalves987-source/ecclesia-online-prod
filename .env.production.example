# ══════════════════════════════════════════════════════════════════════════
# Ecclesia Online — variáveis do ambiente de PRODUÇÃO (Vercel Project: prod)
# ══════════════════════════════════════════════════════════════════════════
#
# Modelo sem valores reais. Configure estes nomes em:
#   Vercel → Projeto de Produção → Settings → Environment Variables
#     (Environment: Production, branch "main")
#
# scripts/check-environment.mjs recusa o build de produção se:
#   - VITE_APP_ENV != "production";
#   - a branch não for "main" (quando detectável);
#   - o domínio não for o domínio oficial;
#   - o project ref não corresponder ao ref de produção configurado.

VITE_APP_ENV=production

# Projeto Supabase de PRODUÇÃO (Ecclesia-Admin).
VITE_SUPABASE_URL=https://SEU_PROJETO_PRODUCAO_REF.supabase.co
VITE_SUPABASE_PUBLISHABLE_KEY=sb_publishable_SUBSTITUA_AQUI
VITE_EXPECTED_SUPABASE_PROJECT_REF=SEU_PROJETO_PRODUCAO_REF

# Domínio oficial de produção.
VITE_PUBLIC_APP_URL=https://SEU_DOMINIO.exemplo

# Allowlist urgente de gestão (ver src/config/modules.ts). Deixe vazio para
# usar somente a allowlist central — não adicione módulos de staging aqui.
VITE_ENABLED_MODULES=

# ── Somente para scripts/check-environment.mjs (build-time, Node) ─────────
SUPABASE_PRODUCTION_REF=SEU_PROJETO_PRODUCAO_REF
SUPABASE_STAGING_REF=SEU_PROJETO_STAGING_REF
OFFICIAL_PRODUCTION_DOMAIN=SEU_DOMINIO.exemplo
