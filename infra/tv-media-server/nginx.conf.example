user nginx;
worker_processes auto;
error_log /var/log/nginx/error.log warn;

events {
    worker_connections 2048;
    use epoll;
}

http {
    include /etc/nginx/mime.types;
    default_type application/octet-stream;

    # Tipos MIME adicionais para HLS
    types {
        application/vnd.apple.mpegurl  m3u8;
        video/mp2t                     ts;
        video/mp4                      mp4;
    }

    # Gzip para manifests HLS
    gzip on;
    gzip_types application/vnd.apple.mpegurl application/json text/plain;
    gzip_min_length 1000;

    # Rate limiting básico
    limit_req_zone $binary_remote_addr zone=hls_limit:10m rate=30r/s;

    sendfile on;
    tcp_nopush on;
    keepalive_timeout 65;

    # ── Logs com IP real (Cloudflare) ─────────────────────────────────────────
    set_real_ip_from 103.21.244.0/22;
    set_real_ip_from 103.22.200.0/22;
    set_real_ip_from 103.31.4.0/22;
    set_real_ip_from 104.16.0.0/13;
    set_real_ip_from 104.24.0.0/14;
    set_real_ip_from 108.162.192.0/18;
    set_real_ip_from 131.0.72.0/22;
    set_real_ip_from 141.101.64.0/18;
    set_real_ip_from 162.158.0.0/15;
    set_real_ip_from 172.64.0.0/13;
    set_real_ip_from 173.245.48.0/20;
    set_real_ip_from 188.114.96.0/20;
    set_real_ip_from 190.93.240.0/20;
    set_real_ip_from 197.234.240.0/22;
    set_real_ip_from 198.41.128.0/17;
    real_ip_header CF-Connecting-IP;

    # ── HTTP → HTTPS redirect ──────────────────────────────────────────────────
    server {
        listen 80;
        server_name media-test.ecclesia.com.br;
        location /.well-known/acme-challenge/ { root /var/www/certbot; }
        location / { return 301 https://$host$request_uri; }
        location /health { return 200 "ok"; }
    }

    # ── HTTPS principal ────────────────────────────────────────────────────────
    server {
        listen 443 ssl http2;
        server_name media-test.ecclesia.com.br;

        ssl_certificate     /etc/ssl/ecclesia/fullchain.pem;
        ssl_certificate_key /etc/ssl/ecclesia/privkey.pem;
        ssl_protocols       TLSv1.2 TLSv1.3;
        ssl_ciphers         HIGH:!aNULL:!MD5;
        ssl_session_cache   shared:SSL:10m;
        ssl_session_timeout 10m;

        add_header Strict-Transport-Security "max-age=31536000" always;
        add_header X-Content-Type-Options nosniff;
        add_header X-Frame-Options SAMEORIGIN;

        # ── HLS: servir segmentos para o player ─────────────────────────────
        # Acessível via: https://media-test.ecclesia.com.br/hls/live/{stream_key}/index.m3u8
        location /hls/ {
            limit_req zone=hls_limit burst=50 nodelay;
            alias /var/www/hls/;

            # Cache: segmentos TS (imutáveis após criação)
            location ~* \.ts$ {
                add_header Cache-Control "public, max-age=86400, immutable";
                add_header Access-Control-Allow-Origin "*";
            }
            # Manifests M3U8 (sem cache — mudam a cada segmento)
            location ~* \.m3u8$ {
                add_header Cache-Control "no-cache, no-store, must-revalidate";
                add_header Access-Control-Allow-Origin "*";
            }
        }

        # ── Proxy para API MediaMTX (health/status) ────────────────────────
        location /mediamtx/ {
            proxy_pass http://localhost:9997/;
            proxy_set_header Host $host;
            proxy_set_header X-Real-IP $remote_addr;
            # Restringir acesso em produção:
            # allow <seu_ip>;
            # deny all;
        }

        # ── WebRTC (opcional) ─────────────────────────────────────────────
        location /webrtc/ {
            proxy_pass http://localhost:8889/;
            proxy_http_version 1.1;
            proxy_set_header Upgrade $http_upgrade;
            proxy_set_header Connection "upgrade";
        }
    }
}
