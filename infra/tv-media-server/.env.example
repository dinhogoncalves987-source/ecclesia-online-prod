# ============================================================================
# .env.example — Ecclesia TV Media Server
# Copiar para .env e preencher com valores reais NUNCA commitar .env com valores.
# ============================================================================

# ── Supabase ──────────────────────────────────────────────────────────────────
# URL do projeto Supabase de TESTE
SUPABASE_URL=https://SEU_PROJETO_TESTE.supabase.co
# Anon key pública (não sensitiva)
SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...
# Service role key (SENSITIVA — nunca expor publicamente)
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# ── Cloudflare R2 ─────────────────────────────────────────────────────────────
# ID da conta Cloudflare (ver: https://dash.cloudflare.com → lado direito)
R2_ACCOUNT_ID=abc123def456
# Chave de acesso R2 (criar em: R2 → Manage R2 API Tokens)
R2_ACCESS_KEY_ID=sua_access_key_id
R2_SECRET_ACCESS_KEY=sua_secret_access_key
# Bucket para gravações da TV
R2_BUCKET_TV=ecclesia-tv-recordings
# Bucket para vídeos do Canal
R2_BUCKET_CANAL=ecclesia-canal-videos
# URL pública do R2 (configurar domínio customizado ou usar o padrão r2.dev)
R2_PUBLIC_URL=https://media.ecclesia.com.br

# ── MediaMTX ──────────────────────────────────────────────────────────────────
# Segredo compartilhado entre MediaMTX e as Edge Functions (gerado aleatoriamente)
MEDIAMTX_WEBHOOK_SECRET=gere_com_openssl_rand_hex_32

# URLs do servidor de streaming (substituir pelo domínio real)
MEDIA_SERVER_HOST=media-test.ecclesia.com.br
MEDIA_RTMP_URL=rtmp://media-test.ecclesia.com.br/live
MEDIA_HLS_BASE_URL=https://media-test.ecclesia.com.br

# ── Paths locais ──────────────────────────────────────────────────────────────
RECORDINGS_DIR=/recordings
HLS_DIR=/hls
SCRIPTS_DIR=/scripts
TEMP_DIR=/tmp/ecclesia

# ── Configurações de gravação ─────────────────────────────────────────────────
MAX_RECORDING_MINUTES=240
THUMBNAIL_OFFSET_SECONDS=30    # capturar thumbnail em t=30s
