# ══════════════════════════════════════════════════════════════════════════
# Ecclesia Online — variáveis do ambiente de STAGING (Vercel Project: staging)
# ══════════════════════════════════════════════════════════════════════════
#
# Modelo sem valores reais. Configure estes nomes em:
#   Vercel → Projeto de Staging → Settings → Environment Variables
#     (Environment: Preview e/ou o Custom Environment "staging")
#
# NUNCA copie os valores reais de produção para staging, e vice-versa.
# scripts/check-environment.mjs recusa o build se o project ref de staging
# coincidir com o de produção.

VITE_APP_ENV=staging

# Projeto Supabase de STAGING (Ecclesia-Admin-Staging). O project ref é um
# identificador PÚBLICO (não é segredo) e é FIXO/CANÔNICO — staging só pode
# usar qkiiwopkbcslquyfhdec (ver CANONICAL_PROJECT_REF em
# src/config/environment.ts e scripts/check-environment.mjs).
VITE_SUPABASE_URL=https://qkiiwopkbcslquyfhdec.supabase.co
VITE_SUPABASE_PUBLISHABLE_KEY=sb_publishable_SUBSTITUA_AQUI
VITE_EXPECTED_SUPABASE_PROJECT_REF=qkiiwopkbcslquyfhdec

# Domínio de staging — deve ser DIFERENTE do domínio oficial de produção
# (ecclesiabr.online), para nunca misturar cache, sessão ou storage do
# navegador entre ambientes.
VITE_PUBLIC_APP_URL=https://staging.SEU_DOMINIO.exemplo

# fail-closed: só habilite conscientemente em staging quando o valor for
# exatamente "true". Qualquer outro valor é tratado como false.
VITE_ENABLE_LEGACY_CHURCH_SCOPE_FALLBACK=true

VITE_ENABLED_MODULES=

# ── Somente para scripts/check-environment.mjs (build-time, Node) ─────────
# Refs canônicos e imutáveis — devem ser exatamente estes valores; o script
# recusa o build se forem omitidos, iguais entre si, ou diferentes destes.
# Não são segredos (são apenas identificadores de projeto/domínio), mas não
# são expostos ao bundle do frontend por não terem o prefixo VITE_.
SUPABASE_PRODUCTION_REF=zsonukpxahaxffugavfu
SUPABASE_STAGING_REF=qkiiwopkbcslquyfhdec
OFFICIAL_PRODUCTION_DOMAIN=ecclesiabr.online
