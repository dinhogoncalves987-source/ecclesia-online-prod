# ══════════════════════════════════════════════════════════════════════════
# Ecclesia Online — modelo de variáveis de ambiente (frontend)
# ══════════════════════════════════════════════════════════════════════════
#
# Este arquivo NUNCA contém valores reais — apenas nomes e placeholders.
# Copie para ".env.local" (desenvolvimento) e preencha com os valores do
# ambiente de STAGING. Uso local de produção é recusado por
# scripts/check-environment.mjs e por src/config/environment.ts.
#
# Para os ambientes reais, use:
#   .env.staging.example     → base para configurar o projeto Vercel Staging
#   .env.production.example  → base para configurar o projeto Vercel Produção
#
# As variáveis efetivas de produção/staging na Vercel são as cadastradas em
# Project Settings → Environment Variables — nunca um arquivo .env commitado.

# "production" ou "staging" — identidade do ambiente, validada por
# src/config/environment.ts antes de qualquer chamada ao Supabase.
VITE_APP_ENV=staging

# URL do projeto Supabase deste ambiente (https://<project-ref>.supabase.co).
VITE_SUPABASE_URL=https://SEU_PROJETO_REF.supabase.co

# Chave publishable (pública, não bypassa RLS) do mesmo projeto Supabase.
VITE_SUPABASE_PUBLISHABLE_KEY=sb_publishable_SUBSTITUA_AQUI

# Project ref esperado — deve ser IGUAL ao ref embutido em
# VITE_SUPABASE_URL. Usado para falhar fechado se as duas variáveis
# divergirem (proteção contra mistura de ambientes).
VITE_EXPECTED_SUPABASE_PROJECT_REF=SEU_PROJETO_REF

# URL pública canônica deste ambiente, usada em convites, QR Codes, cartas,
# compartilhamentos e links públicos. Nunca há fallback silencioso para o
# domínio de produção — se ausente, o app falha fechado.
VITE_PUBLIC_APP_URL=https://SEU_DOMINIO.exemplo

# Lista de módulos habilitados manualmente além da allowlist padrão do
# ambiente (uso avançado/opcional). Vazio = usa somente a allowlist central
# definida em src/config/modules.ts.
VITE_ENABLED_MODULES=
