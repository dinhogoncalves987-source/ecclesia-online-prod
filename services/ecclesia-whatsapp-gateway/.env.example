# =============================================
# Ecclesia WhatsApp Gateway — Variáveis de Ambiente
# =============================================
# Copie este arquivo para .env e preencha os valores.
# NUNCA suba o .env para o repositório.

# ── Servidor ──────────────────────────────────────────────────────────────────
PORT=3100
NODE_ENV=production
LOG_LEVEL=info

# ── Segurança ─────────────────────────────────────────────────────────────────
# Chave de autenticação para o gateway (gerada aleatoriamente)
# Deve ser a mesma usada em VITE_WHATSAPP_GATEWAY_KEY no frontend
GATEWAY_API_KEY=change-me-to-a-strong-random-key

# Origens permitidas (para CORS)
# Em produção, especificar o domínio do Ecclesia
CORS_ORIGIN=https://app.ecclesia.com.br

# ── Modo de operação ──────────────────────────────────────────────────────────
# MOCK_MODE=true  → não conecta ao WhatsApp real, simula respostas
# MOCK_MODE=false → modo real, requer sessão WhatsApp ativa
MOCK_MODE=true

# ── PM2 (opcional, para deploy em VPS) ───────────────────────────────────────
# Configurações para ecosistema PM2
# pm2 start ecosystem.config.js
